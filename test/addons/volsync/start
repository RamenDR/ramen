import sys

from drenv.addons import volsync

if len(sys.argv) < 3 or len(sys.argv) > 4:
    print(f"Usage: {sys.argv[0]} cluster1 cluster2 [skip-test]")
    sys.exit(1)

clusters = sys.argv[1:3]

volsync.start(*clusters)
