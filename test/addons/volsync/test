import sys

from drenv.addons import volsync

if len(sys.argv) < 3 or len(sys.argv) > 4:
    print(f"Usage: {sys.argv[0]} cluster1 cluster2 [skip-test]")
    sys.exit(1)

cluster1, cluster2 = sys.argv[1:3]

# Check if skip-self-test flag is provided
skip_test = len(sys.argv) == 4 and sys.argv[3] == "skip-test"

if skip_test:
    print("Skipping volsync self-test (not supported in this environment)")
    sys.exit(0)

volsync.test(cluster1, cluster2)
