import sys

from drenv.addons import submariner

if len(sys.argv) != 4:
    print(f"Usage: {sys.argv[0]} broker cluster1 cluster2")
    sys.exit(1)

broker = sys.argv[1]
clusters = sys.argv[2:]

submariner.start(broker, *clusters)
