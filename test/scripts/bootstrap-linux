]

RHEL_PACKAGES = [*RPM_PACKAGES, "libvirt", "qemu-kvm"]

FEDORA_PACKAGES = [*RPM_PACKAGES, "@virtualization"]

# Keyed by ID from /etc/os-release.
DISTRO_PACKAGES = {
    "fedora": FEDORA_PACKAGES,
    "rhel": RHEL_PACKAGES,
    "rocky": RHEL_PACKAGES,
    "almalinux": RHEL_PACKAGES,
}

LIBVIRT_DRIVERS = [
    "qemu",
    "network",
    "nodedev",
    "nwfilter",
    "secret",
    "storage",
    "interface",
]

